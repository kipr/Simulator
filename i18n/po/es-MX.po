msgid "The D (derivative) gain numerator"
msgstr "El numerador de la ganancia D (derivada)"

msgctxt "func:get_pid_gains:param:dd:description"
msgid "The D (derivative) gain denominator"
msgstr "El denominador de la ganancia D (derivada)"

msgctxt "func:get_pid_gains:param:i:description"
msgid "The I (integral) gain numerator"
msgstr "El numerador de la ganancia I (integral)"

msgctxt "func:get_pid_gains:param:id:description"
msgid "The I (integral) gain denominator"
msgstr "El denominador de la ganancia I (integral)"

msgctxt "func:get_pid_gains:param:motor:description"
msgid "The motor port."
msgstr "El puerto del motor."

msgctxt "func:get_pid_gains:param:p:description"
msgid "The P (proportional) gain numerator"
msgstr "El numerador de la ganancia P (proporcional)"

msgctxt "func:get_pid_gains:param:pd:description"
msgid "The P (proportional) gain denominator"
msgstr "El denominador de la ganancia P (proporcional)"

