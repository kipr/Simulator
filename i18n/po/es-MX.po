msgstr "El puerto en el que hay que esperar a que se active"

msgctxt "func:wait_for_x_button:detailed"
msgid "Waits (blocks) until the x button has been pressed."
msgstr "Espera (en bloques) hasta que se pulse el botón X."

msgctxt "func:wait_for_x_button_clicked:detailed"
msgid ""
"Waits (blocks) until the x button has been pressed and then subsequently "
