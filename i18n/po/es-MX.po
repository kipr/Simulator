msgstr "Este es el editor de código, donde puedes escribir y editar tu código."

msgid "Click this dropdown to select the programming language for your code."
msgstr "Haz clic en este menú desplegable para seleccionar el lenguaje de programación de tu código."

msgid "Click this button to auto-indent your code."
msgstr "Haz clic en este botón para sangrar automáticamente tu código."

