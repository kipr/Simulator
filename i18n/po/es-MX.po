msgid "The pullup state 1: active 0: inactive"
msgstr "El estado de pullup: 1 = activo, 0 = inactivo"

msgctxt "func:set_digital_value:detailed"
msgid "Sets the value of the digital port in output mode."
msgstr "Establece el valor del puerto digital en modo de salida."

msgctxt "func:set_extra_buttons_visible:detailed"
msgid "Sets whether or not the X, Y, and Z buttons are visible."
msgstr "Establece si los botones X, Y y Z están visibles o no."

msgctxt "func:set_pid_gains:brief"
msgid "Set the motor PID gains, represented as fractions."
msgstr "Configura las ganancias PID del motor, expresadas en fracciones."

msgctxt "func:set_pid_gains:param:d:description"
msgid "The D (derivative) gain numerator"
msgstr "El numerador de la ganancia D (derivada)"

msgctxt "func:set_pid_gains:param:dd:description"
msgid "The D (derivative) gain denominator"
msgstr "El denominador de la ganancia D (derivada)"

msgctxt "func:set_pid_gains:param:i:description"
msgid "The I (integral) gain numerator"
msgstr "El numerador de la ganancia I (integral)"

msgctxt "func:set_pid_gains:param:id:description"
msgid "The I (integral) gain denominator"
msgstr "El denominador de la ganancia I (integral)"

msgctxt "func:set_pid_gains:param:motor:description"
msgid "The motor port."
msgstr "El puerto del motor."

msgctxt "func:set_pid_gains:param:p:description"
msgid "The P (proportional) gain numerator"
msgstr "El numerador de la ganancia P (proporcional)"

msgctxt "func:set_pid_gains:param:pd:description"
msgid "The P (proportional) gain denominator"
msgstr "El denominador de la ganancia P (proporcional)"

msgctxt "func:set_servo_enabled:brief"
msgid "Enable or disable a specific servo."
msgstr "Activa o desactiva un servo específico."

msgctxt "func:set_servo_enabled:param:enabled:description"
msgid "The new enable setting 0: disabled 1: enabled"
msgstr "La nueva configuración de activación: 0: desactivado; 1: activado"

msgctxt "func:set_servo_enabled:param:port:description"
msgid "The port, between 0 and 3, to enable"
msgstr "El puerto, entre 0 y 3, para habilitar"

msgctxt "func:set_servo_position:brief"
msgid "Set a new servo goal position."
msgstr "Establece una nueva posición objetivo del servo."

msgctxt "func:set_servo_position:param:port:description"
msgid "The port of the servo"
msgstr "El puerto del servo"

msgctxt "func:set_servo_position:param:position:description"
msgid "The new servo position, between 0 and 2047"
msgstr "La nueva posición del servo, entre 0 y 2047"

msgctxt "func:set_x_button_text:detailed"
msgid "Updates the X button's text. Deprecatednot planned for the Wallaby"
msgstr "Actualiza el texto del botón X. Obsoleto; no está previsto para Wallaby"

msgctxt "func:set_x_button_text:param:text:description"
msgid "The text to display. Limit of 16 characters."
msgstr "El texto que se va a mostrar. Máximo de 16 caracteres."

msgctxt "func:set_y_button_text:detailed"
msgid "Updates the Y button's text. Deprecatednot planned for the Wallaby"
msgstr "Actualiza el texto del botón Y. Obsoleto; no está previsto para Wallaby"

msgctxt "func:set_y_button_text:param:text:description"
msgid "The text to display. Limit of 16 characters."
msgstr "El texto que se va a mostrar. Máximo de 16 caracteres."

msgctxt "func:set_z_button_text:detailed"
msgid "Updates the Z button's text. Deprecatednot planned for the Wallaby"
msgstr "Actualiza el texto del botón Z. Obsoleto; no está previsto para Wallaby"

msgctxt "func:set_z_button_text:param:text:description"
msgid "The text to display. Limit of 16 characters."
msgstr "El texto que se va a mostrar. Máximo de 16 caracteres."

msgctxt "func:setpwm:brief"
msgid "Set the motor pwm (percent power) command."
msgstr "Configura el comando PWM del motor (porcentaje de potencia)."

msgctxt "func:setpwm:param:motor:description"
msgid "The motor port."
msgstr "El puerto del motor."

msgctxt "func:setpwm:param:pwm:description"
msgid "A new motor pwm command between 0 and 100"
msgstr "Un nuevo comando PWM para el motor entre 0 y 100"

msgctxt "func:shut_down_in:detailed"
msgid "Register an event to stop the user program after s seconds"
msgstr "Registra un evento para detener el programa del usuario tras s segundos"

msgctxt "func:shut_down_in:param:s:description"
msgid "The number of seconds to wait before the end of program"
msgstr "El número de segundos que hay que esperar hasta que termine el programa"

msgctxt "func:side_button:detailed"
msgid ""
"Gets the side button's state (pressed or not pressed.) DeprecatedNot "
"present on the Wallaby"
msgstr "Obtiene el estado del botón lateral (pulsado o no pulsado). Obsoleto. No está disponible en el Wallaby"

msgctxt "func:side_button_clicked:detailed"
msgid "Gets the Z button's state (pressed or not pressed.)"
msgstr "Obtiene el estado del botón Z (pulsado o no pulsado)"

msgctxt "func:wait_for_a_button:detailed"
msgid "Waits (blocks) until the a button has been pressed."
msgstr "Espera (en espera) hasta que se pulse el botón a."

msgctxt "func:wait_for_a_button_clicked:detailed"
msgid ""
"Waits (blocks) until the a button has been pressed and then subsequently "
"released."
msgstr "Espera (en espera) hasta que se pulse un botón y luego se suelte."

msgctxt "func:wait_for_any_button:detailed"
msgid "Waits (blocks) until any system button has been pressed."
msgstr "Espera (en bloque) hasta que se pulse cualquier botón del sistema."

msgctxt "func:wait_for_b_button:detailed"
msgid "Waits (blocks) until the b button has been pressed."
msgstr "Espera (en espera) hasta que se pulse el botón b."

msgctxt "func:wait_for_b_button_clicked:detailed"
msgid ""
"Waits (blocks) until the b button has been pressed and then subsequently "
"released."
msgstr "Espera (en espera) hasta que se pulse el botón «b» y, a continuación, se suelte."

msgctxt "func:wait_for_c_button:detailed"
msgid "Waits (blocks) until the c button has been pressed."
msgstr "Espera (en bloques) hasta que se pulse la tecla «c»."

msgctxt "func:wait_for_c_button_clicked:detailed"
msgid ""
"Waits (blocks) until the c button has been pressed and then subsequently "
"released."
msgstr "Espera (bloquea) hasta que se pulse el botón «c» y luego se suelte."

msgctxt "func:wait_for_light:detailed"
msgid ""
"Initiate a calibration and wait for light sequence which is a normal early "
"step in Botball programs"
msgstr "Inicia una calibración y espera a que aparezca la secuencia de luces, que es un paso inicial habitual en los programas de Botball"

msgctxt "func:wait_for_light:param:light_port_:description"
msgid "The analog port and light sensor to use."
msgstr "El puerto analógico y el sensor de luz que hay que usar."

msgctxt "func:wait_for_milliseconds:detailed"
msgid "Waits (blocks) for the given number of milliseconds."
msgstr "Espera (se bloquea) durante el número de milisegundos indicado."

msgctxt "func:wait_for_milliseconds:param:msecs:description"
msgid "the number of milliseconds to sleep"
msgstr "el número de milisegundos de espera"

msgctxt "func:wait_for_side_button:detailed"
msgid "Waits (blocks) until the side button has been pressed."
msgstr "Espera (en bloque) hasta que se pulse el botón lateral."

msgctxt "func:wait_for_side_button_clicked:detailed"
