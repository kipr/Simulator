msgctxt "struct:mutex:brief"
msgid "A mutex, or lock."
msgstr "Un mutex o bloqueo."

msgctxt "struct:mutex:detailed"
msgid ""
"mutexes are used to prevent memory errors when two programs or threads need "
"to access the same variable."
msgstr "los mutex se utilizan para evitar errores de memoria cuando dos programas o hilos necesitan acceder a la misma variable."

msgctxt "struct:mutex:member:data:brief"
msgid "a C++ Mutex object cast to a void*. Not intended to be accessed."
msgstr "un objeto Mutex C++ convertido en un void*. No está pensado para ser accedido."

msgctxt "struct:point2:brief"
msgid "A 2D point; has x and y."
msgstr "Un punto 2D; tiene x e y."

msgctxt "struct:point2:member:x:brief"
msgid "the x value of the point"
msgstr "el valor x del punto"

msgctxt "struct:point2:member:y:brief"
msgid "the y value of the point"
msgstr "el valor y del punto"

msgctxt "struct:point3:brief"
msgid "A 3D point; has x, y, and z."
msgstr "Un punto 3D; tiene x, y y z."

msgctxt "struct:point3:member:x:brief"
msgid "the x value of the point"
msgstr "el valor x del punto"

msgctxt "struct:point3:member:y:brief"
msgid "the y value of the point"
msgstr "el valor y del punto"

msgctxt "struct:point3:member:z:brief"
msgid "the z value of the point"
msgstr "el valor z del punto"

msgctxt "struct:rectangle:brief"
msgid "A rectangle object."
msgstr "Un objeto rectángulo."

msgctxt "struct:rectangle:member:height:brief"
msgid "the height of the rectangle"
msgstr "la altura del rectángulo"

msgctxt "struct:rectangle:member:ulx:brief"
msgid "the x value of the rectangle's upper left"
msgstr "el valor x de la parte superior izquierda del rectángulo"

msgctxt "struct:rectangle:member:uly:brief"
msgid "the y value of the rectangle's upper left"
msgstr "el valor y de la parte superior izquierda del rectángulo"

msgctxt "struct:rectangle:member:width:brief"
msgid "the width of the rectangle"
msgstr "la anchura del rectángulo"

msgctxt "struct:thread:brief"
msgid "A thread, or separate process."
msgstr "Un hilo, o proceso independiente."

msgctxt "struct:thread:detailed"
msgid ""
"a thread runs a function \"in the background\" (while another function is "
"executing)."
msgstr "un hilo ejecuta una función \ejecutando)."

msgctxt "struct:thread:member:data:brief"
msgid "a C++ Thread object cast to a void*. Not intended to be accessed."
msgstr "un objeto Hilo C++ convertido a void*. No está pensado para ser accedido."

