msgstr "Ang layunin na bilis ay mula -1500 hanggang 1500 na tik / segundo"

msgctxt "func:motor:brief"
msgid "Moves a motor at a percent velocity."
msgstr "Ginagalaw ang isang motor sa porsyentong bilis."

msgctxt "func:motor:param:motor:description"
msgid "The motor port."
msgstr "Ang daungan ng motor."

msgctxt "func:motor:param:percent:description"
msgid "The percent of the motors velocity, between -100 and 100."
msgstr "Ang porsyento ng bilis ng motor, mula -100 hanggang 100."

msgctxt "func:motor_power:brief"
msgid "Moves a motor at a percent power."
msgstr "Ginagalaw ang isang motor sa isang porsyentong lakas."

msgctxt "func:motor_power:param:motor:description"
msgid "the motor port."
msgstr "ang daungan ng makina"

msgctxt "func:motor_power:param:percent:description"
msgid "The power of the motor, between -100 and 100."
msgstr "Ang lakas ng motor, sa pagitan ng -100 at 100."

msgctxt "func:move_at_velocity:brief"
msgid "Set a goal velocity in ticks per second."
msgstr "Itakda ang layunin na bilis sa mga tik kada segundo."

msgctxt "func:move_at_velocity:detailed"
msgid ""
"The range is -1500 to 1500, though motor position accuracy may be decreased "
"outside of -1000 to 1000"
msgstr "Ang saklaw ay -1500 hanggang 1500, ngunit maaaring bumaba ang katumpakan ng posisyon ng motor kapag nasa labas ng -1000 hanggang 1000."

msgctxt "func:move_at_velocity:param:motor:description"
msgid "The motor port."
msgstr "Ang daungan ng motor."

msgctxt "func:move_at_velocity:param:velocity:description"
msgid "The goal velocity in -1500 to 1500 ticks / second"
msgstr "Ang layunin na bilis ay mula -1500 hanggang 1500 na tik / segundo"

msgctxt "func:move_relative_position:brief"
msgid ""
"Set a goal position (in ticks) for the motor to move to, relative to the "
"current position."
msgstr "Itakda ang posisyong layunin (sa mga tik) na pupuntahan ng motor, batay sa kasalukuyang posisyon."

msgctxt "func:move_relative_position:param:delta_pos:description"
msgid "The position to move to (in ticks) given the current position"
msgstr "Ang posisyon na lilipat (sa mga tick) batay sa kasalukuyang posisyon"

msgctxt "func:move_relative_position:param:motor:description"
msgid "The motor port."
msgstr "Ang daungan ng motor."

msgctxt "func:move_relative_position:param:speed:description"
msgid "The speed to move at, between -1500 and 1500 ticks / second"
msgstr "Ang bilis ng paggalaw, sa pagitan ng -1500 at 1500 na tik / segundo"

msgctxt "func:move_to_position:brief"
msgid "Set a goal position (in ticks) for the motor to move to."
msgstr "Itakda ang posisyong layunin (sa mga tik) na pupuntahan ng motor."

msgctxt "func:move_to_position:detailed"
msgid ""
"There are approximately 1500 ticks per motor revolution.This function is "
"more accurate if speeds between -1000 and 1000 are used."
msgstr "Mayroong humigit-kumulang 1500 ticks bawat rebolusyon ng motor. Mas tumpak ang pagganap na ito kung gagamitin ang mga bilis sa pagitan ng -1000 at 1000."

msgctxt "func:move_to_position:param:goal_pos:description"
msgid "The position to move to (in ticks)"
msgstr "Ang posisyon na lilipat (sa mga tik)"

msgctxt "func:move_to_position:param:motor:description"
msgid "The motor port."
msgstr "Ang daungan ng motor."

msgctxt "func:move_to_position:param:speed:description"
msgid "The speed to move at, between -1500 and 1500 ticks / second"
msgstr "Ang bilis ng paggalaw, sa pagitan ng -1500 at 1500 na tik / segundo"

msgctxt "func:mrp:brief"
msgid ""
"Set a goal position (in ticks) for the motor to move to, relative to the "
"current position."
msgstr "Itakda ang posisyong layunin (sa mga tik) para ilipat ng motor, batay sa kasalukuyang posisyon."

msgctxt "func:mrp:param:delta_pos:description"
msgid "The position to move to (in ticks) given the current position"
msgstr "Ang posisyong lilipat (sa mga tick) batay sa kasalukuyang posisyon"

msgctxt "func:mrp:param:motor:description"
msgid "The motor port."
msgstr "Ang daungan ng motor."

msgctxt "func:mrp:param:speed:description"
msgid "The speed to move at, between -1500 and 1500 ticks / second"
msgstr "Ang bilis ng paggalaw, sa pagitan ng -1500 at 1500 na tik / segundo"

msgctxt "func:mtp:brief"
msgid "Set a goal position (in ticks) for the motor to move to."
msgstr "Itakda ang posisyong layunin (sa mga tik) na pupuntahan ng motor."

msgctxt "func:mtp:param:goal_pos:description"
msgid "The position to move to (in ticks)"
msgstr "Ang posisyon na lilipat (sa mga tik)"

msgctxt "func:mtp:param:motor:description"
msgid "The motor port."
msgstr "Ang daungan ng motor."

msgctxt "func:mtp:param:speed:description"
msgid "The speed to move at, between -1500 and 1500 ticks / second"
msgstr "Ang bilis ng paggalaw, sa pagitan ng -1500 at 1500 na tik / segundo"

msgctxt "func:off:brief"
msgid "Turns the specified motor off."
msgstr "Pinapatay ang tinukoy na motor."

msgctxt "func:off:param:motor:description"
msgid "the motor's port."
msgstr "ang daungan ng makina"

msgctxt "func:push_button:detailed"
msgid "Gets the ousg button's state (pressed or not pressed.)"
msgstr "Kino-kuma ang estado ng ousg button (nakapindot o hindi nakapindot)."

msgctxt "func:right_button:detailed"
msgid "Gets the right button's state (pressed or not pressed.)"
msgstr "Kunin ang estado ng tamang pindutan (nakapindot o hindi nakapindot)."

msgctxt "func:set_a_button_text:detailed"
msgid "Updates the A button's text. Deprecatednot planned for the Wallaby"
msgstr "Ina-update ang teksto ng pindutang A. Lipas na; hindi nakaplano para sa Wallaby."

msgctxt "func:set_a_button_text:param:text:description"
msgid "The text to display. Limit of 16 characters."
msgstr "Ang teksto na ipapakita. Limitasyon: 16 na karakter."

msgctxt "func:set_analog_pullup:detailed"
msgid "Sets analog pullup status for one port. Deprecatedno effect on the Wallaby"
msgstr "Itinatakda ang analog pullup na estado para sa isang port. Hindi na ginagamit; walang epekto sa Wallaby."

msgctxt "func:set_analog_pullup:param:port:description"
msgid "A value between 0 and 5 specifying the analog sensor to read from."
msgstr "Isang halaga mula 0 hanggang 5 na naglalahad kung aling analog sensor ang babasahin."

msgctxt "func:set_analog_pullup:param:pullup:description"
msgid "A value of 0 (inactive) or 1 (active)."
msgstr "Halagang 0 (hindi aktibo) o 1 (aktibo)."

msgctxt "func:set_b_button_text:detailed"
msgid "Updates the B button's text. Deprecatednot planned for the Wallaby"
msgstr "Ina-update ang teksto ng pindutang B. Lipas na; hindi nakaplano para sa Wallaby."

msgctxt "func:set_b_button_text:param:text:description"
msgid "The text to display. Limit of 16 characters."
msgstr "Ang teksto na ipapakita. Limitasyon: 16 na karakter."

msgctxt "func:set_c_button_text:detailed"
msgid "Updates the C button's text. Deprecatednot planned for the Wallaby"
msgstr "Ina-update ang teksto ng pindutang C. Lipas na; hindi nakaplano para sa Wallaby."

msgctxt "func:set_c_button_text:param:text:description"
msgid "The text to display. Limit of 16 characters."
msgstr "Ang teksto na ipapakita. Limitasyon: 16 na karakter."

msgctxt "func:set_digital_output:detailed"
msgid "Sets the digital mode."
msgstr "Itinatakda ang digital na mode."

msgctxt "func:set_digital_output:param:out:description"
msgid "1 for output mode, 0 for input mode."
msgstr "1 para sa output mode, 0 para sa input mode."

msgctxt "func:set_digital_output:param:port:description"
msgid "The port to modify."
msgstr "Ang daungan na babaguhin."

msgctxt "func:set_digital_pullup:detailed"
msgid ""
"Sets the current digital pullup state Deprecatednot applicable on the "
"Wallaby"
msgstr "Itinatakda ang kasalukuyang estado ng digital pullup. Hindi na ginagamit; hindi naaangkop sa Wallaby."

msgctxt "func:set_digital_pullup:param:port:description"
msgid "The port to modify"
msgstr "Ang daungan na babaguhin"

msgctxt "func:set_digital_pullup:param:pullup:description"
msgid "The pullup state 1: active 0: inactive"
msgstr "Ang estado ng pullup 1: aktibo 0: hindi aktibo"

msgctxt "func:set_digital_value:detailed"
msgid "Sets the value of the digital port in output mode."
msgstr "Itinatakda ang halaga ng digital na port sa output mode."

msgctxt "func:set_extra_buttons_visible:detailed"
msgid "Sets whether or not the X, Y, and Z buttons are visible."
msgstr "Itinatakda kung nakikita o hindi ang mga pindutang X, Y, at Z."

msgctxt "func:set_pid_gains:brief"
msgid "Set the motor PID gains, represented as fractions."
msgstr "Itakda ang mga PID gain ng motor, na ipinapakita bilang mga bahagi."

msgctxt "func:set_pid_gains:param:d:description"
msgid "The D (derivative) gain numerator"
msgstr "Ang numerador ng D (deribatibo) na kita"

msgctxt "func:set_pid_gains:param:dd:description"
msgid "The D (derivative) gain denominator"
msgstr "Ang denominador ng D (deribatibo) na kita"

msgctxt "func:set_pid_gains:param:i:description"
msgid "The I (integral) gain numerator"
msgstr "Ang numerador ng I (integral) na tubo"

msgctxt "func:set_pid_gains:param:id:description"
msgid "The I (integral) gain denominator"
msgstr "Ang denominator ng I (integral) na tubo"

msgctxt "func:set_pid_gains:param:motor:description"
msgid "The motor port."
msgstr "Ang daungan ng motor."

msgctxt "func:set_pid_gains:param:p:description"
msgid "The P (proportional) gain numerator"
msgstr "Ang numerador ng P (proporsyonal) na kinita"

msgctxt "func:set_pid_gains:param:pd:description"
msgid "The P (proportional) gain denominator"
msgstr "Ang denominador ng P (proporsyonal) na panalo"

msgctxt "func:set_servo_enabled:brief"
msgid "Enable or disable a specific servo."
msgstr "I-enable o i-disable ang isang partikular na servo."

msgctxt "func:set_servo_enabled:param:enabled:description"
msgid "The new enable setting 0: disabled 1: enabled"
msgstr "Ang bagong setting para paganahin: 0: hindi pinagana 1: pinagana"

msgctxt "func:set_servo_enabled:param:port:description"
msgid "The port, between 0 and 3, to enable"
msgstr "Ang port, sa pagitan ng 0 at 3, upang paganahin"

msgctxt "func:set_servo_position:brief"
msgid "Set a new servo goal position."
msgstr "Itakda ang bagong posisyon ng layunin ng servo."

msgctxt "func:set_servo_position:param:port:description"
msgid "The port of the servo"
msgstr "Ang port ng servo"

msgctxt "func:set_servo_position:param:position:description"
msgid "The new servo position, between 0 and 2047"
msgstr "Ang bagong posisyon ng servo, sa pagitan ng 0 at 2047"

msgctxt "func:set_x_button_text:detailed"
msgid "Updates the X button's text. Deprecatednot planned for the Wallaby"
msgstr "Ina-update ang teksto ng X na pindutan. Lipas na; hindi nakaplano para sa Wallaby."

