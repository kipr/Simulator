msgstr "Ang teksto na ipapakita. Limitasyon: 16 na karakter."

msgctxt "func:setpwm:brief"
msgid "Set the motor pwm (percent power) command."
msgstr "Itakda ang motor PWM (porsyento ng kapangyarihan) na utos."

msgctxt "func:setpwm:param:motor:description"
msgid "The motor port."
msgstr "Ang daungan ng motor."

msgctxt "func:setpwm:param:pwm:description"
msgid "A new motor pwm command between 0 and 100"
msgstr "Isang bagong motor PWM na utos sa pagitan ng 0 at 100"

msgctxt "func:shut_down_in:detailed"
msgid "Register an event to stop the user program after s seconds"
msgstr "Magrehistro ng kaganapan upang ihinto ang programang gumagamit pagkatapos ng s segundo."

msgctxt "func:shut_down_in:param:s:description"
msgid "The number of seconds to wait before the end of program"
msgstr "Ang bilang ng mga segundo na dapat hintayin bago matapos ang programa"

msgctxt "func:side_button:detailed"
msgid ""
"Gets the side button's state (pressed or not pressed.) DeprecatedNot "
"present on the Wallaby"
msgstr "Kino-kuma ang estado ng side button (nakapindot o hindi nakapindot). Hindi na ginagamit. Hindi available sa Wallaby."

msgctxt "func:side_button_clicked:detailed"
msgid "Gets the Z button's state (pressed or not pressed.)"
msgstr "Kino-kuma ang estado ng pindutang Z (nakapindot o hindi nakapindot)."

msgctxt "func:wait_for_a_button:detailed"
msgid "Waits (blocks) until the a button has been pressed."
msgstr "Naghihintay (nagba-block) hanggang mapindot ang pindutang A."

msgctxt "func:wait_for_a_button_clicked:detailed"
msgid ""
"Waits (blocks) until the a button has been pressed and then subsequently "
"released."
msgstr "Nag-aantay (nagba-block) hanggang pindutin ang pindutang A at pagkatapos ay pakawalan ito."

msgctxt "func:wait_for_any_button:detailed"
msgid "Waits (blocks) until any system button has been pressed."
msgstr "Naghihintay (nagba-block) hanggang pindutin ang anumang pindutan ng sistema."

msgctxt "func:wait_for_b_button:detailed"
msgid "Waits (blocks) until the b button has been pressed."
msgstr "Naghihintay (nagba-block) hanggang mapindot ang pindutang B."

msgctxt "func:wait_for_b_button_clicked:detailed"
msgid ""
"Waits (blocks) until the b button has been pressed and then subsequently "
"released."
msgstr "Naghihintay (nagba-block) hanggang pindutin ang b button at pagkatapos ay pakawalan ito."

msgctxt "func:wait_for_c_button:detailed"
msgid "Waits (blocks) until the c button has been pressed."
msgstr "Naghihintay (nagba-block) hanggang mapindot ang pindutang C."

msgctxt "func:wait_for_c_button_clicked:detailed"
msgid ""
"Waits (blocks) until the c button has been pressed and then subsequently "
"released."
msgstr "Naghihintay (nagba-block) hanggang pindutin ang pindutang C at pagkatapos ay pakawalan ito."

msgctxt "func:wait_for_light:detailed"
msgid ""
"Initiate a calibration and wait for light sequence which is a normal early "
"step in Botball programs"
msgstr "Simulan ang kalibrasyon at hintayin ang pagkakasunod-sunod ng mga ilaw, na karaniwang unang hakbang sa mga programang Botball."

msgctxt "func:wait_for_light:param:light_port_:description"
msgid "The analog port and light sensor to use."
msgstr "Ang analog port at sensor ng liwanag na gagamitin."

msgctxt "func:wait_for_milliseconds:detailed"
msgid "Waits (blocks) for the given number of milliseconds."
msgstr "Nag-aantay (nagbo-block) ng ibinigay na bilang ng milisekundo."

msgctxt "func:wait_for_milliseconds:param:msecs:description"
msgid "the number of milliseconds to sleep"
msgstr "ang bilang ng millisecond ng pagtulog"

msgctxt "func:wait_for_side_button:detailed"
msgid "Waits (blocks) until the side button has been pressed."
msgstr "Naghihintay (nagba-block) hanggang mapindot ang side button."

msgctxt "func:wait_for_side_button_clicked:detailed"
msgid ""
"Waits (blocks) until the side button has been pressed and then subsequently "
"released."
msgstr "Naghihintay (nagba-block) hanggang mapindot ang side button at pagkatapos ay mabi-bitawan ito."

msgctxt "func:wait_for_touch:detailed"
msgid ""
"Waits (blocks) until the digital sensor on the given port has been "
"activated."
msgstr "Nag-aantay (nagba-block) hanggang sa ma-aktiba ang digital sensor sa ibinigay na port."

msgctxt "func:wait_for_touch:param:port:description"
msgid "The port to wait for activation on"
msgstr "Ang daungan na hihintayin para sa pag-aktibo"

msgctxt "func:wait_for_x_button:detailed"
msgid "Waits (blocks) until the x button has been pressed."
msgstr "Naghihintay (nagba-block) hanggang mapindot ang x na pindutan."

msgctxt "func:wait_for_x_button_clicked:detailed"
msgid ""
"Waits (blocks) until the x button has been pressed and then subsequently "
"released."
msgstr "Naghihintay (nagba-block) hanggang pindutin ang x na pindutan at pagkatapos ay pakawalan ito."

msgctxt "func:wait_for_y_button:detailed"
msgid "Waits (blocks) until the y button has been pressed."
msgstr "Naghihintay (nagba-block) hanggang mai-press ang pindutang Y."

msgctxt "func:wait_for_y_button_clicked:detailed"
msgid ""
"Waits (blocks) until the y button has been pressed and then subsequently "
"released."
msgstr "Naghihintay (nagba-block) hanggang pindutin ang pindutang Y at pagkatapos ay pakawalan ito."

msgctxt "func:wait_for_z_button:detailed"
msgid "Waits (blocks) until the z button has been pressed."
msgstr "Naghihintay (nagba-block) hanggang mapindot ang pindutang Z."

msgctxt "func:wait_for_z_button_clicked:detailed"
msgid ""
"Waits (blocks) until the z button has been pressed and then subsequently "
"released."
msgstr "Naghihintay (nagba-block) hanggang mapindot ang pindutang Z at pagkatapos ay mabi-bitawan ito."

